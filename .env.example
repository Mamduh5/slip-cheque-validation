NEXT_PUBLIC_APP_NAME="Document Registry Checker"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

MONGODB_URI="mongodb://mongo:27017/slip_cheque_validation"
MONGODB_DB="slip_cheque_validation"

MINIO_ENDPOINT="minio"
MINIO_PORT="9000"
MINIO_USE_SSL="false"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="document-images"

MAX_UPLOAD_MB="10"

# Optional. When omitted, the Google button is shown disabled.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
